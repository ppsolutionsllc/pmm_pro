COMPOSE_PROJECT_NAME=pmm-dev

POSTGRES_USER=pmm
POSTGRES_PASSWORD=pmm
POSTGRES_DB=pmm

JWT_SECRET=local-dev-jwt-secret-key-with-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
PRINT_QR_TARGET_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend
ENABLE_SECURITY_HEADERS=false

SQL_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10

FIRST_ADMIN_LOGIN=
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FULL_NAME=First Administrator

ARTIFACTS_DIR=/var/lib/pmm/artifacts
BACKUP_DIR=/var/lib/pmm/backups
BACKUP_RETENTION_COUNT=10
POSTING_ERROR_LOG_PATH=/var/log/pmm/posting_errors.log

BACKEND_VERSION=dev
FRONTEND_VERSION=dev

DEV_DB_PORT=5432
DEV_BACKEND_PORT=8000
DEV_FRONTEND_PORT=3000
VITE_DEV_PROXY_TARGET=http://backend:8000
