# =========================
# Local development (docker-compose.yml)
# =========================

# Database
DATABASE_URL=postgresql+asyncpg://pmm:pmm@db:5432/pmm

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
CORS_ORIGINS=http://localhost:3000
SQL_ECHO=false
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_VERSION=dev
FRONTEND_VERSION=dev

# Optional one-time first admin bootstrap values for CLI command
# Used by: python -m app.cli create-first-admin
FIRST_ADMIN_LOGIN=
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FULL_NAME=First Administrator

# Storage / artifacts
ARTIFACTS_DIR=/tmp/pmm_artifacts
BACKUP_DIR=/tmp/pmm_backups
BACKUP_RETENTION_COUNT=10
POSTING_ERROR_LOG_PATH=/tmp/pmm_posting_errors.log

# Update system (optional in local)
APP_VERSION=dev
PMM_BACKEND_IMAGE=docker.io/your-org/pmm-backend:dev
PMM_FRONTEND_IMAGE=docker.io/your-org/pmm-frontend:dev
PMM_WORKER_IMAGE=docker.io/your-org/pmm-worker:dev
UPDATE_MANIFEST_PATH=/app/app/update_manifest.json
UPDATE_MANIFEST_URL=
UPDATE_MANIFEST_SHA256_PIN=
ALLOWED_IMAGE_REPOS=docker.io/your-org/pmm-backend,docker.io/your-org/pmm-frontend,docker.io/your-org/pmm-worker
UPDATE_GITHUB_REPO=
UPDATE_GITHUB_TOKEN=
REQUIRE_SIGNED_TAGS=false
UPDATE_CHECK_CACHE_TTL_SECONDS=300
UPDATE_RELEASES_LIMIT=10
UPDATE_RELEASES_KEEP=5
UPDATE_MIN_FREE_GB=2
UPDATE_LOGS_DIR=/opt/pmm/logs
UPDATE_PROJECT_DIR=/opt/pmm
UPDATE_COMPOSE_FILE=/opt/pmm/docker-compose.prod.yml
UPDATE_ENV_FILE=/opt/pmm/.env.prod
UPDATE_VERSION_ENV_KEY=APP_VERSION
UPDATER_POLL_INTERVAL_SECONDS=5
UPDATER_MODE=false
ENABLE_LEGACY_JSON_RESTORE=false
