# Common environment reference for PMM Online.
# Use `.env.dev` with the dev compose stack and `.env.prod` with the prod stack.
# Do not use this file directly for deployment.

# Compose project naming
COMPOSE_PROJECT_NAME=pmm

# Production host storage root (used by docker-compose.prod.yml)
PMM_DATA_ROOT=/opt/pmm-data

# Database
POSTGRES_USER=pmm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pmm

# Auth
JWT_SECRET=MANUAL_ACTION_REQUIRED__SET_REAL_SECRET__MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Web / security
CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend
ENABLE_SECURITY_HEADERS=true

# Database pool / runtime
SQL_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10

# Optional bootstrap admin
FIRST_ADMIN_LOGIN=
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FULL_NAME=First Administrator

# Persistent runtime paths inside backend container
ARTIFACTS_DIR=/var/lib/pmm/artifacts
BACKUP_DIR=/var/lib/pmm/backups
BACKUP_RETENTION_COUNT=10
POSTING_ERROR_LOG_PATH=/var/log/pmm/posting_errors.log

# Version metadata
BACKEND_VERSION=dev
FRONTEND_VERSION=dev

# Production-only update subsystem
UPDATE_GITHUB_REPO=
UPDATE_GITHUB_TOKEN=
REQUIRE_SIGNED_TAGS=false
UPDATE_CHECK_CACHE_TTL_SECONDS=300
UPDATE_RELEASES_LIMIT=10
UPDATE_RELEASES_KEEP=5
UPDATE_MIN_FREE_GB=2
UPDATE_LOGS_DIR=/opt/pmm/logs
UPDATE_PROJECT_DIR=/opt/pmm
UPDATE_COMPOSE_FILE=/opt/pmm/current/docker-compose.prod.yml
UPDATE_ENV_FILE=/opt/pmm/.env.prod
UPDATE_VERSION_ENV_KEY=APP_VERSION
UPDATER_POLL_INTERVAL_SECONDS=5
UPDATER_MODE=false
ENABLE_LEGACY_JSON_RESTORE=false
