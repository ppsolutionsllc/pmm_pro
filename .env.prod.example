# =========================================
# Production template (Dokploy / Coolify)
# =========================================

# Domain is configured in platform UI (Dokploy/Coolify).
# Compose does not use DOMAIN for routing anymore.

# Postgres
POSTGRES_USER=pmm
POSTGRES_PASSWORD=MANUAL_ACTION_REQUIRED__SET_IN_DOKPLOY_OR_COOLIFY_SECRET
POSTGRES_DB=pmm

# Auth (REQUIRED)
JWT_SECRET=MANUAL_ACTION_REQUIRED__SET_IN_DOKPLOY_OR_COOLIFY_SECRET__MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Web security / origin
CORS_ORIGINS=https://pmm.66br.pp.ua
FRONTEND_BASE_URL=https://pmm.66br.pp.ua
ALLOWED_HOSTS=pmm.66br.pp.ua
ENABLE_SECURITY_HEADERS=true

# Runtime
SQL_ECHO=false
BACKEND_WORKERS=3
RUN_MIGRATIONS=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
PRINT_QR_TARGET_URL=https://pmm.66br.pp.ua

# Optional one-time first admin bootstrap values for CLI command:
# docker compose -f docker-compose.prod.yml run --rm backend \
#   python -m app.cli create-first-admin
FIRST_ADMIN_LOGIN=
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FULL_NAME=First Administrator

# Version metadata (optional)
APP_VERSION=1.0.0
PMM_BACKEND_IMAGE=pmm-backend:1.0.0
PMM_FRONTEND_IMAGE=pmm-frontend:1.0.0

# Update subsystem (optional)
UPDATE_GITHUB_REPO=
UPDATE_GITHUB_TOKEN=
REQUIRE_SIGNED_TAGS=false
UPDATE_CHECK_CACHE_TTL_SECONDS=300
UPDATE_RELEASES_LIMIT=10
UPDATE_RELEASES_KEEP=5
UPDATE_MIN_FREE_GB=2
UPDATE_LOGS_DIR=/opt/pmm/logs
UPDATE_PROJECT_DIR=/opt/pmm
UPDATE_COMPOSE_FILE=/opt/pmm/current/docker-compose.prod.yml
UPDATE_ENV_FILE=/opt/pmm/.env.prod
UPDATE_VERSION_ENV_KEY=APP_VERSION
UPDATER_POLL_INTERVAL_SECONDS=5
UPDATER_MODE=false
ENABLE_LEGACY_JSON_RESTORE=false

# Persistent runtime data
ARTIFACTS_DIR=/var/lib/pmm/artifacts
BACKUP_DIR=/var/lib/pmm/backups
BACKUP_RETENTION_COUNT=10
POSTING_ERROR_LOG_PATH=/var/log/pmm/posting_errors.log
