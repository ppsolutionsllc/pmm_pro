# =========================
# Production (docker-compose.prod.yml)
# =========================

# Postgres
POSTGRES_USER=pmm
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=pmm

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
CORS_ORIGINS=https://your-domain.example
FRONTEND_BASE_URL=https://your-domain.example
ALLOWED_HOSTS=your-domain.example
ENABLE_SECURITY_HEADERS=true
DOMAIN=your-domain.example.com
SQL_ECHO=false
BACKEND_WORKERS=3
# Used by docker-compose.coolify.yml when publishing frontend port.
FRONTEND_BIND_PORT=8080
RUN_MIGRATIONS=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10

# Optional one-time first admin bootstrap values for CLI command
# Used by: docker compose --env-file .env.prod -f docker-compose.prod.yml run --rm backend python -m app.cli create-first-admin
FIRST_ADMIN_LOGIN=
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FULL_NAME=First Administrator

# Versioned images
APP_VERSION=1.0.0
PMM_BACKEND_IMAGE=pmm-backend:1.0.0
PMM_FRONTEND_IMAGE=pmm-frontend:1.0.0
PMM_WORKER_IMAGE=pmm-worker:1.0.0

# Update system
UPDATE_GITHUB_REPO=your-org/pmm-online
UPDATE_GITHUB_TOKEN=
REQUIRE_SIGNED_TAGS=false
UPDATE_CHECK_CACHE_TTL_SECONDS=300
UPDATE_RELEASES_LIMIT=10
UPDATE_RELEASES_KEEP=5
UPDATE_MIN_FREE_GB=2
UPDATE_LOGS_DIR=/opt/pmm/logs
UPDATE_PROJECT_DIR=/opt/pmm
UPDATE_COMPOSE_FILE=/opt/pmm/current/docker-compose.prod.yml
UPDATE_ENV_FILE=/opt/pmm/.env.prod
UPDATE_VERSION_ENV_KEY=APP_VERSION
UPDATER_POLL_INTERVAL_SECONDS=5
UPDATER_MODE=false
ENABLE_LEGACY_JSON_RESTORE=false

# Runtime data
ARTIFACTS_DIR=/var/lib/pmm/artifacts
BACKUP_DIR=/var/lib/pmm/backups
BACKUP_RETENTION_COUNT=10
POSTING_ERROR_LOG_PATH=/var/log/pmm/posting_errors.log
