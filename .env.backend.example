# Backend-only local run (without docker-compose)
DATABASE_URL=postgresql+asyncpg://pmm:pmm@localhost:5432/pmm
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
ENABLE_SECURITY_HEADERS=true
SQL_ECHO=false
FRONTEND_BASE_URL=http://localhost:3000
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10

# Optional bootstrap values for CLI first admin creation
FIRST_ADMIN_LOGIN=
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FULL_NAME=First Administrator

ARTIFACTS_DIR=/tmp/pmm_artifacts
BACKUP_DIR=/tmp/pmm_backups
BACKUP_RETENTION_COUNT=10
POSTING_ERROR_LOG_PATH=/tmp/pmm_posting_errors.log
RUN_MIGRATIONS=false
